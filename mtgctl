#!/usr/bin/env bash
set -euo pipefail

VERSION="1.2"

# ====== defaults ======
MTG_CONTAINER_DEFAULT="mtg-proxy"
MTG_IMAGE_DEFAULT="nineseconds/mtg:2"

MTG_ETC_DIR_DEFAULT="/etc/mtg"
MTG_CONFIG_DEFAULT="/etc/mtg/mtg.toml"
MTG_STATE_DEFAULT="/etc/mtg/state.env"
MTG_UPSTREAM_FILE_DEFAULT="/etc/mtg/upstreams.list"

# ====== helpers ======
log()  { printf "%b\n" "$*"; }
info() { log "✅ $*"; }
warn() { log "⚠️  $*"; }
err()  { log "❌ $*" >&2; }
die()  { err "$*"; exit 1; }

is_root() { [[ "${EUID:-$(id -u)}" -eq 0 ]]; }
need_root() { is_root || die "Нужны права root. Запускай так: sudo mtgctl <command>"; }

have_cmd() { command -v "$1" >/dev/null 2>&1; }

trim() {
  local s="${1:-}"
  # shellcheck disable=SC2001
  s="$(echo "$s" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
  printf "%s" "$s"
}

toml_escape() {
  # escape backslash and double quotes for TOML basic strings
  local s="${1:-}"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf "%s" "$s"
}

# ====== paths/state ======
MTG_CONTAINER="${MTG_CONTAINER:-$MTG_CONTAINER_DEFAULT}"
MTG_IMAGE="${MTG_IMAGE:-$MTG_IMAGE_DEFAULT}"

MTG_ETC_DIR="${MTG_ETC_DIR:-$MTG_ETC_DIR_DEFAULT}"
MTG_CONFIG="${MTG_CONFIG:-$MTG_CONFIG_DEFAULT}"
MTG_STATE="${MTG_STATE:-$MTG_STATE_DEFAULT}"
MTG_UPSTREAM_FILE="${MTG_UPSTREAM_FILE:-$MTG_UPSTREAM_FILE_DEFAULT}"

load_state() {
  if [[ -f "$MTG_STATE" ]]; then
    # shellcheck disable=SC1090
    set -a; source "$MTG_STATE"; set +a
  fi
}

save_state() {
  mkdir -p "$MTG_ETC_DIR"
  cat >"$MTG_STATE" <<STATE
# generated by mtgctl
VERSION="${VERSION}"
MTG_CONTAINER="${MTG_CONTAINER}"
MTG_IMAGE="${MTG_IMAGE}"
MTG_ETC_DIR="${MTG_ETC_DIR}"
MTG_CONFIG="${MTG_CONFIG}"
MTG_STATE="${MTG_STATE}"
MTG_UPSTREAM_FILE="${MTG_UPSTREAM_FILE}"
MTG_PORT="${MTG_PORT}"
MTG_DOMAIN="${MTG_DOMAIN}"
MTG_SECRET_HEX="${MTG_SECRET_HEX}"
STATE
  chmod 600 "$MTG_STATE"
}

render_config() {
  mkdir -p "$MTG_ETC_DIR"

  # base minimal config
  cat >"$MTG_CONFIG" <<CFG
# generated by mtgctl v${VERSION}
# minimal mtg config (FakeTLS)
secret = "${MTG_SECRET_HEX}"
bind-to = "0.0.0.0:${MTG_PORT}"
CFG

  # optional upstream socks5 proxies (proxy chaining)
  local proxies_items=()
  if [[ -f "$MTG_UPSTREAM_FILE" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
      # strip comments
      line="${line%%#*}"
      line="$(trim "$line")"
      [[ -n "$line" ]] || continue

      # allow "DIRECT" marker or literal "" to mean empty-string fallback
      if [[ "$line" == "DIRECT" || "$line" == "direct" || "$line" == "\"\"" ]]; then
        proxies_items+=('""')
      else
        proxies_items+=("\"$(toml_escape "$line")\"")
      fi
    done <"$MTG_UPSTREAM_FILE"
  fi

  if ((${#proxies_items[@]} > 0)); then
    {
      echo
      echo "[network]"
      echo "proxies = ["
      local item
      for item in "${proxies_items[@]}"; do
        echo "  ${item},"
      done
      echo "]"
    } >>"$MTG_CONFIG"
  fi

  chmod 600 "$MTG_CONFIG"
}

# ====== checks ======
port_in_use() {
  local p="$1"
  ss -lntp 2>/dev/null | grep -qE "LISTEN.*:${p}\b"
}

ensure_apt_pkg() {
  local pkg="$1"
  if ! dpkg -s "$pkg" >/dev/null 2>&1; then
    info "Устанавливаю пакет: $pkg"
    DEBIAN_FRONTEND=noninteractive apt-get update -y >/dev/null
    DEBIAN_FRONTEND=noninteractive apt-get install -y "$pkg"
  fi
}

ensure_docker() {
  if ! have_cmd docker; then
    info "Docker не найден — ставлю docker.io (Ubuntu repo)"
    ensure_apt_pkg ca-certificates
    ensure_apt_pkg curl
    ensure_apt_pkg docker.io
  fi
  if have_cmd systemctl; then
    systemctl enable --now docker >/dev/null 2>&1 || true
  fi
  docker version >/dev/null 2>&1 || die "Docker установлен, но не работает. Проверь: systemctl status docker"
}

ensure_tools() {
  ensure_apt_pkg curl
  ensure_apt_pkg jq
  ensure_apt_pkg iproute2
}

ensure_image() {
  info "Пуллю образ: ${MTG_IMAGE}"
  docker pull "$MTG_IMAGE" >/dev/null
}

ufw_allow_if_active() {
  local p="$1"
  if have_cmd ufw; then
    if ufw status 2>/dev/null | grep -qi "Status: active"; then
      info "UFW активен — открываю TCP порт ${p}"
      ufw allow "${p}/tcp" >/dev/null
    else
      warn "UFW установлен, но не активен — порт ${p} скрипт не трогает."
    fi
  else
    warn "UFW не установлен — если у тебя включён облачный firewall/security-group, открой TCP ${p} там."
  fi
}

container_exists() { docker inspect "$MTG_CONTAINER" >/dev/null 2>&1; }
container_running() { docker inspect -f '{{.State.Running}}' "$MTG_CONTAINER" 2>/dev/null | grep -q true; }

run_container_fresh() {
  docker rm -f "$MTG_CONTAINER" >/dev/null 2>&1 || true

  # NOTE: host-network intentionally:
  # - allows binding privileged ports directly
  # - allows upstream socks5 on 127.0.0.1 to be reachable from container
  info "Запускаю контейнер ${MTG_CONTAINER} (host network, listen=${MTG_PORT})"
  docker run -d \
    --name "$MTG_CONTAINER" \
    --restart unless-stopped \
    --network host \
    --dns 8.8.8.8 --dns 9.9.9.9 \
    --log-driver json-file --log-opt max-size=10m --log-opt max-file=3 \
    -v "$MTG_CONFIG":/config.toml:ro \
    "$MTG_IMAGE" >/dev/null
}

write_upstream_file() {
  need_root
  mkdir -p "$MTG_ETC_DIR"
  : >"$MTG_UPSTREAM_FILE"
  chmod 600 "$MTG_UPSTREAM_FILE"
}

# ====== commands ======
cmd_install() {
  need_root
  ensure_tools
  ensure_docker
  ensure_image

  mkdir -p "$MTG_ETC_DIR"
  touch "$MTG_UPSTREAM_FILE"
  chmod 600 "$MTG_UPSTREAM_FILE"

  local default_port="${MTG_PORT:-443}"
  local default_domain="${MTG_DOMAIN:-cloudflare.com}"

  if [[ -z "${MTG_PORT:-}" ]]; then
    read -r -p "Порт для клиентов (рекомендую 443) [${default_port}]: " MTG_PORT || true
    MTG_PORT="${MTG_PORT:-$default_port}"
  fi

  [[ "$MTG_PORT" =~ ^[0-9]+$ ]] || die "Порт должен быть числом"
  (( MTG_PORT >= 1 && MTG_PORT <= 65535 )) || die "Порт должен быть 1..65535"
  if port_in_use "$MTG_PORT"; then
    die "Порт ${MTG_PORT} уже занят (ss показывает LISTEN). Выбери другой."
  fi

  if [[ -z "${MTG_DOMAIN:-}" ]]; then
    echo
    warn "FakeTLS домен лучше выбирать 'правдоподобный' для твоего IP/провайдера."
    read -r -p "FakeTLS домен [${default_domain}]: " MTG_DOMAIN || true
    MTG_DOMAIN="${MTG_DOMAIN:-$default_domain}"
  fi

  info "Генерирую FakeTLS secret (hex, начинается с ee...) для домена: ${MTG_DOMAIN}"
  MTG_SECRET_HEX="$(docker run --rm "$MTG_IMAGE" generate-secret --hex "$MTG_DOMAIN" | tr -d '\r\n')"
  [[ "$MTG_SECRET_HEX" =~ ^ee[0-9a-fA-F]+$ ]] || die "Неожиданный формат секрета: ${MTG_SECRET_HEX}"

  echo
  warn "Proxy chaining (двойной контур): mtg может ходить к Telegram через SOCKS5 апстрим(ы)."
  warn "Формат: socks5://user:password@host:port?open_threshold=5&half_open_timeout=1m&reset_failures_timeout=10s"
  warn "Если вставляешь URL с символами & или ?, ОБЯЗАТЕЛЬНО оберни в одинарные кавычки в командной строке."
  read -r -p "SOCKS5 upstream (опционально; пусто = не использовать): " upstream || true
  upstream="$(trim "$upstream")"
  : >"$MTG_UPSTREAM_FILE"
  if [[ -n "$upstream" ]]; then
    echo "$upstream" >>"$MTG_UPSTREAM_FILE"
  fi

  save_state
  render_config

  ufw_allow_if_active "$MTG_PORT"

  run_container_fresh

  info "Готово. Ссылки для подключения:"
  cmd_link || true

  echo
  info "Управление: mtgctl status | start | stop | restart | logs | link"
  info "Апстримы:  sudo mtgctl upstream show|set|add|add-direct|clear"
}

cmd_status() {
  load_state
  have_cmd docker || die "docker не найден. Если это другой пользователь — запускай через sudo."
  if ! container_exists; then
    warn "Контейнер ${MTG_CONTAINER} не найден."
    exit 1
  fi

  local running started
  running="$(docker inspect -f '{{.State.Running}}' "$MTG_CONTAINER" 2>/dev/null || true)"
  started="$(docker inspect -f '{{.State.StartedAt}}' "$MTG_CONTAINER" 2>/dev/null || true)"

  echo "Container: ${MTG_CONTAINER}"
  echo "Image:     ${MTG_IMAGE:-unknown}"
  echo "Running:   ${running}"
  echo "Started:   ${started}"
  [[ -n "${MTG_PORT:-}" ]] && echo "Port:      ${MTG_PORT}"
  [[ -n "${MTG_DOMAIN:-}" ]] && echo "Domain:    ${MTG_DOMAIN}"
}

cmd_start() {
  load_state
  [[ -n "${MTG_PORT:-}" && -n "${MTG_SECRET_HEX:-}" ]] || die "Нет state. Сначала: sudo mtgctl install"
  ensure_docker
  ensure_image
  render_config
  run_container_fresh
  info "Запущено."
}

cmd_stop() {
  load_state
  ensure_docker
  if container_exists; then
    docker stop "$MTG_CONTAINER" >/dev/null || true
    info "Остановлено."
  else
    warn "Контейнер не найден."
  fi
}

cmd_restart() { cmd_start; }

cmd_logs() {
  load_state
  ensure_docker
  container_exists || die "Контейнер не найден"
  docker logs --tail 200 -f "$MTG_CONTAINER"
}

cmd_link() {
  load_state
  ensure_docker
  container_exists || die "Контейнер не найден"

  # auto-detect public IPv4 for building tg:// and t.me links
  local ipv4=""
  ipv4="$(curl -4 -fsS https://api.ipify.org 2>/dev/null || true)"
  ipv4="$(trim "$ipv4")"

  local json
  if container_running; then
    if [[ -n "$ipv4" ]]; then
      json="$(docker exec "$MTG_CONTAINER" /mtg access --ipv4 "$ipv4" /config.toml)"
    else
      json="$(docker exec "$MTG_CONTAINER" /mtg access /config.toml)"
    fi
  else
    warn "Контейнер остановлен — вывожу access через docker run."
    if [[ -n "$ipv4" ]]; then
      json="$(docker run --rm --network host -v "$MTG_CONFIG":/config.toml:ro "$MTG_IMAGE" access --ipv4 "$ipv4" /config.toml)"
    else
      json="$(docker run --rm --network host -v "$MTG_CONFIG":/config.toml:ro "$MTG_IMAGE" access /config.toml)"
    fi
  fi

  echo "$json" | jq -r '
    def block(name; obj):
      if obj == null then empty else
      "=== " + name + " ===\n" +
      "IP:      " + obj.ip + "\n" +
      "Port:    " + (obj.port|tostring) + "\n" +
      "tg://    " + obj.tg_url + "\n" +
      "t.me     " + obj.tme_url + "\n" +
      "QR(tg):  " + obj.tg_qrcode + "\n"
      end;

    (block("ipv4"; .ipv4) // "") +
    (block("ipv6"; .ipv6) // "") +
    "\nSecret(hex):    " + .secret.hex + "\n" +
    "Secret(base64): " + .secret.base64 + "\n"
  '
}

cmd_config() {
  load_state
  [[ -f "$MTG_CONFIG" ]] || die "Конфиг не найден: $MTG_CONFIG"
  echo "=== $MTG_CONFIG ==="
  cat "$MTG_CONFIG"
  echo
  echo "=== upstreams file: $MTG_UPSTREAM_FILE ==="
  [[ -f "$MTG_UPSTREAM_FILE" ]] && cat -n "$MTG_UPSTREAM_FILE" || true
}

cmd_gen_secret() {
  ensure_docker
  ensure_image
  local domain="${1:-cloudflare.com}"
  docker run --rm "$MTG_IMAGE" generate-secret --hex "$domain"
}

cmd_rotate_secret() {
  need_root
  load_state
  [[ -n "${MTG_DOMAIN:-}" ]] || die "Нет MTG_DOMAIN в state. Переустанови: sudo mtgctl install"
  ensure_docker
  ensure_image

  info "Ротация секрета (новый secret для домена ${MTG_DOMAIN})"
  MTG_SECRET_HEX="$(docker run --rm "$MTG_IMAGE" generate-secret --hex "$MTG_DOMAIN" | tr -d '\r\n')"
  save_state
  render_config
  run_container_fresh
  info "Секрет обновлён. Новые ссылки:"
  cmd_link || true
}

cmd_set_port() {
  need_root
  load_state
  local p="${1:-}"
  [[ -n "$p" ]] || die "Использование: mtgctl set-port <1..65535>"
  [[ "$p" =~ ^[0-9]+$ ]] || die "Порт должен быть числом"
  (( p >= 1 && p <= 65535 )) || die "Порт должен быть 1..65535"
  if port_in_use "$p"; then
    die "Порт ${p} уже занят."
  fi

  MTG_PORT="$p"
  save_state
  render_config
  ufw_allow_if_active "$MTG_PORT"
  run_container_fresh
  info "Порт изменён на ${MTG_PORT}. Обновлённые ссылки:"
  cmd_link || true
}

cmd_set_domain() {
  need_root
  load_state
  local d="${1:-}"
  [[ -n "$d" ]] || die "Использование: mtgctl set-domain <domain>"
  ensure_docker
  ensure_image

  MTG_DOMAIN="$d"
  info "Новый домен FakeTLS: ${MTG_DOMAIN}. Генерирую новый secret..."
  MTG_SECRET_HEX="$(docker run --rm "$MTG_IMAGE" generate-secret --hex "$MTG_DOMAIN" | tr -d '\r\n')"
  save_state
  render_config
  run_container_fresh
  info "Домен/секрет обновлены. Новые ссылки:"
  cmd_link || true
}

cmd_upstream() {
  load_state
  mkdir -p "$MTG_ETC_DIR"
  touch "$MTG_UPSTREAM_FILE"
  chmod 600 "$MTG_UPSTREAM_FILE"

  local sub="${1:-show}"
  shift || true

  case "$sub" in
    show)
      echo "Upstreams file: $MTG_UPSTREAM_FILE"
      if [[ ! -s "$MTG_UPSTREAM_FILE" ]]; then
        echo "(пусто) — прямой выход без SOCKS5"
      else
        cat -n "$MTG_UPSTREAM_FILE"
      fi
      echo
      echo "Подсказка:"
      echo "  - добавь SOCKS5: sudo mtgctl upstream add 'socks5://user:pass@127.0.0.1:1080'"
      echo "  - добавь fallback DIRECT: sudo mtgctl upstream add-direct   (это добавит \"\" в список)"
      ;;
    set)
      need_root
      ((${#@} >= 1)) || die "Использование: sudo mtgctl upstream set <uri1> [uri2 ...]"
      : >"$MTG_UPSTREAM_FILE"
      local x
      for x in "$@"; do
        x="$(trim "$x")"
        [[ -n "$x" ]] || continue
        if [[ "$x" == "DIRECT" || "$x" == "direct" || "$x" == "''" || "$x" == "\"\"" ]]; then
          echo "\"\"" >>"$MTG_UPSTREAM_FILE"
        else
          echo "$x" >>"$MTG_UPSTREAM_FILE"
        fi
      done
      render_config
      run_container_fresh
      info "Апстримы обновлены. Текущие:"
      cmd_upstream show
      ;;
    add)
      need_root
      local uri="${1:-}"
      [[ -n "$uri" ]] || die "Использование: sudo mtgctl upstream add <uri>"
      uri="$(trim "$uri")"
      [[ -n "$uri" ]] || die "Пустой uri"
      echo "$uri" >>"$MTG_UPSTREAM_FILE"
      render_config
      run_container_fresh
      info "Добавлено. Текущие апстримы:"
      cmd_upstream show
      ;;
    add-direct)
      need_root
      echo "\"\"" >>"$MTG_UPSTREAM_FILE"
      render_config
      run_container_fresh
      info "Добавлен DIRECT (пустая строка \"\"). Текущие апстримы:"
      cmd_upstream show
      ;;
    clear)
      need_root
      : >"$MTG_UPSTREAM_FILE"
      render_config
      run_container_fresh
      info "Апстримы очищены — теперь прямой выход без SOCKS5."
      ;;
    *)
      die "Неизвестная команда upstream: $sub (доступно: show|set|add|add-direct|clear)"
      ;;
  esac
}

cmd_update() {
  need_root
  load_state
  ensure_docker
  ensure_image
  render_config
  run_container_fresh
  info "Обновлено (docker pull + restart)."
}

cmd_uninstall() {
  need_root
  load_state || true
  if have_cmd docker; then
    docker rm -f "$MTG_CONTAINER" >/dev/null 2>&1 || true
  fi
  rm -rf "$MTG_ETC_DIR" >/dev/null 2>&1 || true
  info "Удалено: контейнер + конфиги (${MTG_ETC_DIR})."
}

usage() {
  cat <<USAGE
mtgctl — управление mtg (MTProto FakeTLS proxy) через Docker. v${VERSION}

Команды:
  install                 Установка/настройка (интерактивно спросит порт/домен/апстрим)
  status                  Статус контейнера
  start | stop | restart  Управление
  logs                    Логи (tail+follow)
  link                    Показать tg:// и t.me ссылки + secret
  config                  Показать текущий config.toml и upstreams.list
  gen-secret [domain]     Сгенерировать FakeTLS secret (hex, ee...)
  rotate-secret           Новый secret (для текущего домена) + перезапуск
  set-port <port>         Сменить порт + перезапуск
  set-domain <domain>     Сменить FakeTLS домен (и secret) + перезапуск

  upstream <subcmd> ...   Proxy chaining (SOCKS5 апстримы):
      upstream show
      upstream set <uri1> [uri2 ...]
      upstream add <uri>
      upstream add-direct         (добавит "" как прямой выход)
      upstream clear

  update                  docker pull образа + перезапуск
  uninstall               Удалить контейнер и конфиги

Пример апстрима SOCKS5 (URI):
  socks5://user:password@127.0.0.1:1080?open_threshold=5&half_open_timeout=1m&reset_failures_timeout=10s

ВАЖНО: если в URI есть & или ?, используй одинарные кавычки:
  sudo mtgctl upstream set 'socks5://127.0.0.1:1080?open_threshold=5&half_open_timeout=1m'

USAGE
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    install)         cmd_install "$@" ;;
    status)          cmd_status "$@" ;;
    start)           cmd_start "$@" ;;
    stop)            cmd_stop "$@" ;;
    restart)         cmd_restart "$@" ;;
    logs)            cmd_logs "$@" ;;
    link)            cmd_link "$@" ;;
    config)          cmd_config "$@" ;;
    gen-secret)      cmd_gen_secret "$@" ;;
    rotate-secret)   cmd_rotate_secret "$@" ;;
    set-port)        cmd_set_port "$@" ;;
    set-domain)      cmd_set_domain "$@" ;;
    upstream)        cmd_upstream "$@" ;;
    update)          cmd_update "$@" ;;
    uninstall)       cmd_uninstall "$@" ;;
    help|-h|--help)  usage ;;
    *)               usage; die "Неизвестная команда: $cmd" ;;
  esac
}

main "$@"
